upsert_spectral_block() {
  local file="$1"
  local block_fn="$2"
  local label="$3"

  if [ -f "$file" ] && grep -q "Spectral Review Agents" "$file" 2>/dev/null; then
    # Replace existing block
    local tmp
    tmp=$(mktemp)
    awk '
      /^## Spectral Review Agents/ { skip=1; next }
      /^## / { if (skip) { skip=0 } }
      !skip
    ' "$file" > "$tmp"
    echo "" >> "$tmp"
    $block_fn >> "$tmp"
    mv "$tmp" "$file"
    success "$label: Updated Spectral block in $file"
  elif [ -f "$file" ]; then
    echo "" >> "$file"
    $block_fn >> "$file"
    success "$label: Added Spectral reference to $file"
  else
    $block_fn > "$file"
    success "$label: Created $file"
  fi
}

remove_spectral_block() {
  local file="$1"
  local label="$2"

  if [ -f "$file" ] && grep -q "Spectral Review Agents" "$file" 2>/dev/null; then
    local tmp
    tmp=$(mktemp)
    awk '
      /^## Spectral Review Agents/ { skip=1; next }
      /^## / { if (skip) { skip=0 } }
      !skip
    ' "$file" > "$tmp"
    # Remove trailing blank lines
    if command -v perl >/dev/null 2>&1; then
      perl -pi -e 'chomp if eof' "$tmp"
    fi
    mv "$tmp" "$file"
    # If file is now empty (or only whitespace), remove it
    if [ ! -s "$file" ] || ! grep -q '[^[:space:]]' "$file" 2>/dev/null; then
      rm -f "$file"
      success "$label: Removed $file (was Spectral-only)"
    else
      success "$label: Removed Spectral block from $file"
    fi
  fi
}

# ── Install Functions ────────────────────────────────────────────────────────

install_claude_code() {
  # Claude Code agents: ~/.claude/agents/*.md
  # Format: Markdown with YAML frontmatter (name, description, tools, model)
  # Instruction file: ~/.claude/CLAUDE.md
  local target="$HOME/.claude/agents"
  mkdir -p "$target"

  local count=0
  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    cp "$agent" "$target/$(basename "$agent")"
    count=$((count + 1))
  done
  success "Claude Code: $count agents -> $target"

  # Clean up stale agents from previous versions
  for stale in "${STALE_AGENTS[@]}"; do
    if [ -f "$target/$stale.md" ]; then
      rm -f "$target/$stale.md"
      info "Claude Code: Removed stale agent $stale.md"
    fi
  done

  upsert_spectral_block "$HOME/.claude/CLAUDE.md" spectral_block_claude "Claude Code"
}

install_cursor() {
  # Cursor rules: .cursor/rules/*.mdc
  # Format: .mdc with YAML frontmatter (description, alwaysApply, globs)
  # Instruction file: .cursorrules
  warn_if_not_project_root "Cursor" || return 0

  local target=".cursor/rules"
  mkdir -p "$target"

  local count=0
  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    local name
    name=$(basename "$agent" .md)

    # Extract description for Cursor frontmatter
    local desc
    desc=$(extract_description_first_line "$agent")
    if [ -z "$desc" ]; then
      desc="Spectral $name review agent"
    fi
    # Escape double quotes for YAML
    desc="${desc//\"/\\\"}"
    # Truncate description to 200 chars for Cursor
    if [ ${#desc} -gt 200 ]; then
      desc="${desc:0:197}..."
    fi

    # Write .mdc with Cursor-compatible frontmatter
    {
      echo "---"
      echo "description: \"$desc\""
      echo "alwaysApply: false"
      echo "---"
      echo ""
      extract_agent_body "$agent"
    } > "$target/spectral-${name}.mdc"

    count=$((count + 1))
  done
  success "Cursor: $count rules -> $target"

  # Clean up stale agents from previous versions
  for stale in "${STALE_AGENTS[@]}"; do
    if [ -f "$target/spectral-$stale.mdc" ]; then
      rm -f "$target/spectral-$stale.mdc"
      info "Cursor: Removed stale rule spectral-$stale.mdc"
    fi
  done

  upsert_spectral_block ".cursorrules" spectral_block_cursor "Cursor"
}

install_codex() {
  # Codex CLI reads AGENTS.md files — it walks from repo root to CWD,
  # loading AGENTS.md at each level. We append agent instructions directly
  # into the project's AGENTS.md so Codex picks them up automatically.
  # Ref: https://developers.openai.com/codex/guides/agents-md/
  warn_if_not_project_root "Codex" || return 0

  local agents_md="AGENTS.md"

  # Build the full Spectral section for AGENTS.md
  local spectral_section
  spectral_section=$(mktemp)

  spectral_block_codex > "$spectral_section"

  # Append each agent's full instructions under its own heading
  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    local name
    name=$(basename "$agent" .md)
    echo "" >> "$spectral_section"
    echo "### Spectral: $name" >> "$spectral_section"
    echo "" >> "$spectral_section"
    extract_agent_body "$agent" >> "$spectral_section"
  done

  local count=${#AGENT_NAMES[@]}

  # Upsert into AGENTS.md
  if [ -f "$agents_md" ] && grep -q "Spectral Review Agents" "$agents_md" 2>/dev/null; then
    # Replace existing Spectral section
    local tmp
    tmp=$(mktemp)
    awk '
      /^## Spectral Review Agents/ { skip=1; next }
      /^## / { if (skip) { skip=0 } }
      !skip
    ' "$agents_md" > "$tmp"
    echo "" >> "$tmp"
    cat "$spectral_section" >> "$tmp"
    mv "$tmp" "$agents_md"
    success "Codex: Updated $count agents in $agents_md"
  elif [ -f "$agents_md" ]; then
    echo "" >> "$agents_md"
    cat "$spectral_section" >> "$agents_md"
    success "Codex: Added $count agents to $agents_md"
  else
    cat "$spectral_section" > "$agents_md"
    success "Codex: Created $agents_md with $count agents"
  fi

  rm -f "$spectral_section"
}

# ── Uninstall Functions ──────────────────────────────────────────────────────

uninstall_claude_code() {
  local target="$HOME/.claude/agents"
  local removed=0
  for name in "${AGENT_NAMES[@]}" "${STALE_AGENTS[@]}"; do
    if [ -f "$target/$name.md" ]; then
      rm -f "$target/$name.md"
      removed=$((removed + 1))
    fi
  done

  if [ "$removed" -gt 0 ]; then
    success "Claude Code: Removed $removed agents from $target"
  fi

  remove_spectral_block "$HOME/.claude/CLAUDE.md" "Claude Code"
}

uninstall_cursor() {
  local removed
  removed=$(count_matching_files ".cursor/rules" "spectral-*.mdc")
  if [ "$removed" -gt 0 ]; then
    rm -f .cursor/rules/spectral-*.mdc
    success "Cursor: Removed $removed rule files"
  fi

  remove_spectral_block ".cursorrules" "Cursor"
}

uninstall_codex() {
  # Remove Spectral section from AGENTS.md
  remove_spectral_block "AGENTS.md" "Codex"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_install() {
  local targets=("$@")

  # Handle --help / -h before banner
  if [ ${#targets[@]} -gt 0 ] && [[ "${targets[0]}" == "-h" || "${targets[0]}" == "--help" ]]; then
    echo "Usage: spectral install [tool...]"
    echo ""
    echo "Install agents to detected tools, or specify tools explicitly."
    echo "Tools: claude-code, cursor, codex"
    echo ""
    echo "Also updates instruction files (CLAUDE.md, .cursorrules, AGENTS.md)"
    echo "so the AI knows the agents are available."
    echo ""
    echo "Run again after updating Spectral to refresh all agents and instructions."
    return 0
  fi

  print_banner
  ensure_agents
  detect_tools

  # If no targets specified, use all detected tools
  if [ ${#targets[@]} -eq 0 ]; then
    if [ ${#DETECTED_TOOLS[@]} -eq 0 ]; then
      err "No AI coding tools detected on this machine."
      echo ""
      info "Supported: Claude Code, Cursor, Codex CLI"
      info "Install a tool first, or specify a target explicitly:"
      echo ""
      echo "    spectral install claude-code"
      echo "    spectral install cursor"
      echo "    spectral install codex"
      echo ""
      exit 1
    fi
    targets=("${DETECTED_TOOLS[@]}")
  fi

  header "Detected tools"
  for tool in "${DETECTED_TOOLS[@]}"; do
    info "$tool"
  done

  header "Installing $(agent_count) agents"
  echo ""

  for target in "${targets[@]}"; do
    case "$target" in
      claude-code|claude) install_claude_code ;;
      cursor)             install_cursor ;;
      codex)              install_codex ;;
      *)
        warn "Unknown tool: $target (supported: claude-code, cursor, codex)"
        ;;
    esac
  done

  echo ""
  success "Done! Run 'spectral status' to verify."
  echo ""
}

cmd_uninstall() {
  local targets=("$@")

  print_banner

  if [ ${#targets[@]} -eq 0 ]; then
    targets=("claude-code" "cursor" "codex")
  fi

  header "Uninstalling Spectral"
  echo ""

  for target in "${targets[@]}"; do
    case "$target" in
      claude-code|claude) uninstall_claude_code ;;
      cursor)             uninstall_cursor ;;
      codex)              uninstall_codex ;;
      *)
        warn "Unknown tool: $target"
        ;;
    esac
  done

  echo ""
  success "Done!"
  echo ""
}

cmd_status() {
  print_banner
  detect_tools

  header "Tool Detection"
  echo ""

  local total_agents=${#AGENT_NAMES[@]}

  # Claude Code
  if [[ " ${DETECTED_TOOLS[*]} " =~ " claude-code " ]]; then
    local count=0
    for name in "${AGENT_NAMES[@]}"; do
      if [ -f "$HOME/.claude/agents/$name.md" ]; then
        count=$((count + 1))
      fi
    done
    if [ "$count" -gt 0 ]; then
      success "Claude Code: ${GREEN}installed${NC} ($count/$total_agents agents)"
    else
      info "Claude Code: ${YELLOW}detected, not installed${NC}"
    fi
  else
    info "Claude Code: ${DIM}not detected${NC}"
  fi

  # Cursor
  if [[ " ${DETECTED_TOOLS[*]} " =~ " cursor " ]]; then
    local count
    count=$(count_matching_files ".cursor/rules" "spectral-*.mdc")
    if [ "$count" -gt 0 ]; then
      success "Cursor: ${GREEN}installed${NC} ($count/$total_agents rules)"
    else
      info "Cursor: ${YELLOW}detected, not installed${NC}"
    fi
  else
    info "Cursor: ${DIM}not detected${NC}"
  fi

  # Codex
  if [[ " ${DETECTED_TOOLS[*]} " =~ " codex " ]]; then
    if [ -f "AGENTS.md" ] && grep -q "Spectral Review Agents" "AGENTS.md" 2>/dev/null; then
      success "Codex: ${GREEN}installed${NC} (in AGENTS.md)"
    else
      info "Codex: ${YELLOW}detected, not installed${NC}"
    fi
  else
    info "Codex: ${DIM}not detected${NC}"
  fi

  echo ""
  info "Tool not detected? Specify it explicitly: spectral install <tool>"
  echo ""
}

cmd_list() {
  print_banner
  ensure_agents

  header "Available Agents"
  echo ""

  printf "  ${BOLD}%-24s %s${NC}\n" "AGENT" "FOCUS"
  printf "  ${DIM}%-24s %s${NC}\n" "------------------------" "----------------------------------------"

  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    local name
    name=$(basename "$agent" .md)
    local desc
    desc=$(extract_description_first_line "$agent")
    if [ -z "$desc" ]; then
      desc="(no description)"
    fi
    if [ ${#desc} -gt 50 ]; then
      desc="${desc:0:47}..."
    fi
    printf "  %-24s %s\n" "$name" "$desc"
  done

  echo ""
}

cmd_help() {
  print_banner

  echo -e "  ${BOLD}USAGE${NC}"
  echo "    spectral <command> [options]"
  echo ""
  echo -e "  ${BOLD}COMMANDS${NC}"
  echo "    install [tool...]    Install agents to detected (or specified) tools"
  echo "    uninstall [tool...]  Remove agents and instruction blocks"
  echo "    status               Show which tools are detected and installed"
  echo "    list                 List all available review agents"
  echo "    help                 Show this help message"
  echo "    version              Show version"
  echo ""
  echo -e "  ${BOLD}TOOLS${NC}"
  echo "    claude-code          ~/.claude/agents/ + ~/.claude/CLAUDE.md"
  echo "    cursor               .cursor/rules/*.mdc + .cursorrules"
  echo "    codex                AGENTS.md (Codex auto-discovers this file)"
  echo ""
  echo -e "  ${BOLD}EXAMPLES${NC}"
  echo "    spectral install                  # Auto-detect and install everywhere"
  echo "    spectral install claude-code      # Install only for Claude Code"
  echo "    spectral install cursor codex     # Install for specific tools"
  echo "    spectral uninstall                # Remove from everywhere"
  echo "    spectral status                   # Check what's installed"
  echo ""
  echo -e "  ${BOLD}UPDATING${NC}"
  echo "    git pull && ./spectral install    # Re-run install to update agents"
  echo ""
}

# ── Main ─────────────────────────────────────────────────────────────────────

if [ $# -eq 0 ]; then
  cmd_help
  exit 0
fi

CMD="$1"
shift

case "$CMD" in
  install)              cmd_install "$@" ;;
  uninstall|remove)     cmd_uninstall "$@" ;;
  status)               cmd_status ;;
  list|ls)              cmd_list ;;
  help|-h|--help)       cmd_help ;;
  version|-v|--version) echo "spectral $VERSION" ;;
  *)
    err "Unknown command: $CMD"
    echo ""
    echo "  Run 'spectral help' for usage."
    exit 1
    ;;
esac
