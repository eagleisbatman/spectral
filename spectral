upsert_spectral_block() {
  # Inserts or replaces the spectral block in a file.
  # $1 = file path, $2 = block generator function, $3 = display label
  local file="$1"
  local block_fn="$2"
  local label="$3"

  if [ -f "$file" ] && grep -q "Spectral Review Agents" "$file" 2>/dev/null; then
    # Replace existing block
    local tmp
    tmp=$(mktemp)
    awk '
      /^## Spectral Review Agents/ { skip=1; next }
      /^## / { if (skip) { skip=0 } }
      !skip
    ' "$file" > "$tmp"
    # Append fresh block
    echo "" >> "$tmp"
    $block_fn >> "$tmp"
    mv "$tmp" "$file"
    success "$label: Updated Spectral block in $file"
  elif [ -f "$file" ]; then
    echo "" >> "$file"
    $block_fn >> "$file"
    success "$label: Added Spectral reference to $file"
  else
    $block_fn > "$file"
    success "$label: Created $file"
  fi
}

remove_spectral_block() {
  # Removes the spectral block from a file.
  # $1 = file path, $2 = display label
  local file="$1"
  local label="$2"

  if [ -f "$file" ] && grep -q "Spectral Review Agents" "$file" 2>/dev/null; then
    local tmp
    tmp=$(mktemp)
    awk '
      /^## Spectral Review Agents/ { skip=1; next }
      /^## / { if (skip) { skip=0 } }
      !skip
    ' "$file" > "$tmp"
    # Remove trailing blank lines
    if command -v perl >/dev/null 2>&1; then
      perl -pi -e 'chomp if eof' "$tmp"
    fi
    mv "$tmp" "$file"
    # If file is now empty (or only whitespace), remove it
    if [ ! -s "$file" ] || ! grep -q '[^[:space:]]' "$file" 2>/dev/null; then
      rm -f "$file"
      success "$label: Removed $file (was Spectral-only)"
    else
      success "$label: Removed Spectral block from $file"
    fi
  fi
}

# ── Install Functions ────────────────────────────────────────────────────────

install_claude_code() {
  local target="$HOME/.claude/agents"
  mkdir -p "$target"

  local count=0
  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    cp "$agent" "$target/$(basename "$agent")"
    count=$((count + 1))
  done
  success "Claude Code: $count agents -> $target"

  upsert_spectral_block "$HOME/.claude/CLAUDE.md" spectral_block_claude "Claude Code"
}

install_cursor() {
  warn_if_not_project_root "Cursor" || return 0

  local target=".cursor/rules"
  mkdir -p "$target"

  local count=0
  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    local name
    name=$(basename "$agent" .md)
    cp "$agent" "$target/spectral-${name}.mdc"
    count=$((count + 1))
  done
  success "Cursor: $count rules -> $target"

  upsert_spectral_block ".cursorrules" spectral_block_cursor "Cursor"
}

install_windsurf() {
  warn_if_not_project_root "Windsurf" || return 0

  local target=".windsurf/rules"
  mkdir -p "$target"

  local count=0
  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    local name
    name=$(basename "$agent" .md)
    cp "$agent" "$target/spectral-${name}.md"
    count=$((count + 1))
  done
  success "Windsurf: $count rules -> $target"

  upsert_spectral_block ".windsurfrules" spectral_block_windsurf "Windsurf"
}

install_codex() {
  warn_if_not_project_root "Codex" || return 0

  local target=".codex/spectral"
  mkdir -p "$target"

  local count=0
  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    cp "$agent" "$target/$(basename "$agent")"
    count=$((count + 1))
  done
  success "Codex: $count agents -> $target"

  upsert_spectral_block "codex.md" spectral_block_codex "Codex"
}

# ── Uninstall Functions ──────────────────────────────────────────────────────

uninstall_claude_code() {
  local target="$HOME/.claude/agents"
  local removed=0
  for name in "${AGENT_NAMES[@]}"; do
    if [ -f "$target/$name.md" ]; then
      rm -f "$target/$name.md"
      removed=$((removed + 1))
    fi
  done

  if [ "$removed" -gt 0 ]; then
    success "Claude Code: Removed $removed agents from $target"
  fi

  remove_spectral_block "$HOME/.claude/CLAUDE.md" "Claude Code"
}

uninstall_cursor() {
  local removed
  removed=$(count_matching_files ".cursor/rules" "spectral-*.mdc")
  if [ "$removed" -gt 0 ]; then
    rm -f .cursor/rules/spectral-*.mdc
    success "Cursor: Removed $removed rule files"
  fi

  remove_spectral_block ".cursorrules" "Cursor"
}

uninstall_windsurf() {
  local removed
  removed=$(count_matching_files ".windsurf/rules" "spectral-*.md")
  if [ "$removed" -gt 0 ]; then
    rm -f .windsurf/rules/spectral-*.md
    success "Windsurf: Removed $removed rule files"
  fi

  remove_spectral_block ".windsurfrules" "Windsurf"
}

uninstall_codex() {
  if [ -d ".codex/spectral" ]; then
    rm -rf ".codex/spectral"
    success "Codex: Removed .codex/spectral/"
  fi

  remove_spectral_block "codex.md" "Codex"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_install() {
  local targets=("$@")

  # Handle --help / -h before banner
  if [ ${#targets[@]} -gt 0 ] && [[ "${targets[0]}" == "-h" || "${targets[0]}" == "--help" ]]; then
    echo "Usage: spectral install [tool...]"
    echo ""
    echo "Install agents to detected tools, or specify tools explicitly."
    echo "Tools: claude-code, cursor, windsurf, codex"
    echo ""
    echo "Also updates instruction files (CLAUDE.md, .cursorrules, etc.)"
    echo "so the AI knows the agents are available."
    echo ""
    echo "Run again after updating Spectral to refresh all agents and instructions."
    return 0
  fi

  print_banner
  ensure_agents
  detect_tools

  # If no targets specified, use all detected tools
  if [ ${#targets[@]} -eq 0 ]; then
    if [ ${#DETECTED_TOOLS[@]} -eq 0 ]; then
      err "No AI coding tools detected on this machine."
      echo ""
      info "Supported: Claude Code, Cursor, Windsurf, Codex CLI"
      info "Install a tool first, or specify a target explicitly:"
      echo ""
      echo "    spectral install claude-code"
      echo "    spectral install cursor"
      echo "    spectral install windsurf"
      echo "    spectral install codex"
      echo ""
      exit 1
    fi
    targets=("${DETECTED_TOOLS[@]}")
  fi

  header "Detected tools"
  for tool in "${DETECTED_TOOLS[@]}"; do
    info "$tool"
  done

  header "Installing $(agent_count) agents"
  echo ""

  for target in "${targets[@]}"; do
    case "$target" in
      claude-code|claude) install_claude_code ;;
      cursor)             install_cursor ;;
      windsurf)           install_windsurf ;;
      codex)              install_codex ;;
      *)
        warn "Unknown tool: $target (supported: claude-code, cursor, windsurf, codex)"
        ;;
    esac
  done

  echo ""
  success "Done! Run 'spectral status' to verify."
  echo ""
}

cmd_uninstall() {
  local targets=("$@")

  print_banner

  if [ ${#targets[@]} -eq 0 ]; then
    targets=("claude-code" "cursor" "windsurf" "codex")
  fi

  header "Uninstalling Spectral"
  echo ""

  for target in "${targets[@]}"; do
    case "$target" in
      claude-code|claude) uninstall_claude_code ;;
      cursor)             uninstall_cursor ;;
      windsurf)           uninstall_windsurf ;;
      codex)              uninstall_codex ;;
      *)
        warn "Unknown tool: $target"
        ;;
    esac
  done

  echo ""
  success "Done!"
  echo ""
}

cmd_status() {
  print_banner
  detect_tools

  header "Tool Detection"
  echo ""

  local total_agents=${#AGENT_NAMES[@]}

  # Claude Code
  if [[ " ${DETECTED_TOOLS[*]} " =~ " claude-code " ]]; then
    local count=0
    for name in "${AGENT_NAMES[@]}"; do
      if [ -f "$HOME/.claude/agents/$name.md" ]; then
        count=$((count + 1))
      fi
    done
    if [ "$count" -gt 0 ]; then
      success "Claude Code: ${GREEN}installed${NC} ($count/$total_agents agents)"
    else
      info "Claude Code: ${YELLOW}detected, not installed${NC}"
    fi
  else
    info "Claude Code: ${DIM}not detected${NC}"
  fi

  # Cursor
  if [[ " ${DETECTED_TOOLS[*]} " =~ " cursor " ]]; then
    local count
    count=$(count_matching_files ".cursor/rules" "spectral-*.mdc")
    if [ "$count" -gt 0 ]; then
      success "Cursor: ${GREEN}installed${NC} ($count/$total_agents rules)"
    else
      info "Cursor: ${YELLOW}detected, not installed${NC}"
    fi
  else
    info "Cursor: ${DIM}not detected${NC}"
  fi

  # Windsurf
  if [[ " ${DETECTED_TOOLS[*]} " =~ " windsurf " ]]; then
    local count
    count=$(count_matching_files ".windsurf/rules" "spectral-*.md")
    if [ "$count" -gt 0 ]; then
      success "Windsurf: ${GREEN}installed${NC} ($count/$total_agents rules)"
    else
      info "Windsurf: ${YELLOW}detected, not installed${NC}"
    fi
  else
    info "Windsurf: ${DIM}not detected${NC}"
  fi

  # Codex
  if [[ " ${DETECTED_TOOLS[*]} " =~ " codex " ]]; then
    local count
    count=$(count_matching_files ".codex/spectral" "*.md")
    if [ "$count" -gt 0 ]; then
      success "Codex: ${GREEN}installed${NC} ($count/$total_agents agents)"
    else
      info "Codex: ${YELLOW}detected, not installed${NC}"
    fi
  else
    info "Codex: ${DIM}not detected${NC}"
  fi

  echo ""
  info "Tool not detected? Specify it explicitly: spectral install <tool>"
  echo ""
}

cmd_list() {
  print_banner
  ensure_agents

  header "Available Agents"
  echo ""

  printf "  ${BOLD}%-24s %s${NC}\n" "AGENT" "FOCUS"
  printf "  ${DIM}%-24s %s${NC}\n" "------------------------" "----------------------------------------"

  for agent in "$AGENTS_DIR"/*.md; do
    [ -f "$agent" ] || continue
    local name
    name=$(basename "$agent" .md)
    # Extract the first content line of the description from YAML frontmatter
    local desc
    desc=$(awk '/^description:/{found=1; next} found && /^  [^ ]/{gsub(/^  /,""); print; exit}' "$agent")
    if [ -z "$desc" ]; then
      desc="(no description)"
    fi
    # Truncate to 50 chars
    if [ ${#desc} -gt 50 ]; then
      desc="${desc:0:47}..."
    fi
    printf "  %-24s %s\n" "$name" "$desc"
  done

  echo ""
}

cmd_help() {
  print_banner

  echo -e "  ${BOLD}USAGE${NC}"
  echo "    spectral <command> [options]"
  echo ""
  echo -e "  ${BOLD}COMMANDS${NC}"
  echo "    install [tool...]    Install agents to detected (or specified) tools"
  echo "    uninstall [tool...]  Remove agents and instruction blocks"
  echo "    status               Show which tools are detected and installed"
  echo "    list                 List all available review agents"
  echo "    help                 Show this help message"
  echo "    version              Show version"
  echo ""
  echo -e "  ${BOLD}TOOLS${NC}"
  echo "    claude-code          ~/.claude/agents/ + CLAUDE.md"
  echo "    cursor               .cursor/rules/ + .cursorrules"
  echo "    windsurf             .windsurf/rules/ + .windsurfrules"
  echo "    codex                .codex/spectral/ + codex.md"
  echo ""
  echo -e "  ${BOLD}EXAMPLES${NC}"
  echo "    spectral install                  # Auto-detect and install everywhere"
  echo "    spectral install claude-code      # Install only for Claude Code"
  echo "    spectral install cursor windsurf  # Install for specific tools"
  echo "    spectral uninstall                # Remove from everywhere"
  echo "    spectral status                   # Check what's installed"
  echo ""
  echo -e "  ${BOLD}UPDATING${NC}"
  echo "    git pull && ./spectral install    # Re-run install to update agents"
  echo ""
}

# ── Main ─────────────────────────────────────────────────────────────────────

if [ $# -eq 0 ]; then
  cmd_help
  exit 0
fi

CMD="$1"
shift

case "$CMD" in
  install)              cmd_install "$@" ;;
  uninstall|remove)     cmd_uninstall "$@" ;;
  status)               cmd_status ;;
  list|ls)              cmd_list ;;
  help|-h|--help)       cmd_help ;;
  version|-v|--version) echo "spectral $VERSION" ;;
  *)
    err "Unknown command: $CMD"
    echo ""
    echo "  Run 'spectral help' for usage."
    exit 1
    ;;
esac
