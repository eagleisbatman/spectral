#!/bin/bash
# ============================================================================
# Spectral CLI
# Autonomous code review agents for AI coding tools.
# https://github.com/eagleisbatman/spectral
# ============================================================================

set -uo pipefail

# We handle errors manually instead of set -e to avoid && short-circuit traps.
# Every external command that matters is checked explicitly.

VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AGENTS_DIR="$SCRIPT_DIR/agents"
SPECTRAL_TMPDIR=""

# Agent names (single source of truth)
AGENT_NAMES=(
  full-spectrum
  security-audit
  architecture-review
  performance-review
  code-quality
  ux-review
  accessibility-review
  api-review
  data-integrity
)

# Colors (disabled if not a terminal)
if [ -t 1 ]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  CYAN='\033[0;36m'
  DIM='\033[2m'
  BOLD='\033[1m'
  NC='\033[0m'
else
  RED='' GREEN='' YELLOW='' BLUE='' CYAN='' DIM='' BOLD='' NC=''
fi

# ── Helpers ──────────────────────────────────────────────────────────────────

print_banner() {
  echo ""
  echo -e "${BOLD}  ╔═══════════════════════════════════════╗${NC}"
  echo -e "${BOLD}  ║         ${CYAN}S P E C T R A L${NC}${BOLD}               ║${NC}"
  echo -e "${BOLD}  ║   ${DIM}autonomous code review agents${NC}${BOLD}       ║${NC}"
  echo -e "${BOLD}  ╚═══════════════════════════════════════╝${NC}"
  echo ""
}

info()    { echo -e "  ${BLUE}>${NC} $1"; }
success() { echo -e "  ${GREEN}+${NC} $1"; }
warn()    { echo -e "  ${YELLOW}!${NC} $1"; }
err()     { echo -e "  ${RED}x${NC} $1"; }
header()  { echo -e "\n  ${BOLD}$1${NC}"; }

ensure_agents() {
  if [ ! -d "$AGENTS_DIR" ]; then
    info "Agents not found locally. Cloning..."
    SPECTRAL_TMPDIR=$(mktemp -d)
    if git clone --depth 1 https://github.com/eagleisbatman/spectral.git "$SPECTRAL_TMPDIR/spectral" >/dev/null 2>&1; then
      AGENTS_DIR="$SPECTRAL_TMPDIR/spectral/agents"
    else
      err "Failed to clone spectral repo. Check your network connection."
      exit 1
    fi
    if [ ! -d "$AGENTS_DIR" ]; then
      err "Cloned repo but agents/ directory not found."
      exit 1
    fi
  fi
}

cleanup() {
  if [ -n "${SPECTRAL_TMPDIR:-}" ] && [ -d "$SPECTRAL_TMPDIR" ]; then
    rm -rf "$SPECTRAL_TMPDIR"
  fi
}
trap cleanup EXIT

count_matching_files() {
  # Counts files matching a glob pattern safely.
  # Usage: count_matching_files /path/to/dir "pattern"
  local dir="$1"
  local pattern="$2"
  local count=0
  if [ -d "$dir" ]; then
    while IFS= read -r -d '' _; do
      count=$((count + 1))
    done < <(find "$dir" -maxdepth 1 -name "$pattern" -type f -print0 2>/dev/null)
  fi
  echo "$count"
}

agent_count() {
  count_matching_files "$AGENTS_DIR" "*.md"
}

confirm_prompt() {
  # Reads confirmation from /dev/tty so it works even when stdin is piped.
  local message="$1"
  if [ -t 0 ]; then
    read -p "$message" confirm
  elif [ -e /dev/tty ]; then
    read -p "$message" confirm < /dev/tty
  else
    confirm="n"
  fi
  [[ "$confirm" == "y" || "$confirm" == "Y" ]]
}

# ── Detection ────────────────────────────────────────────────────────────────

detect_tools() {
  DETECTED_TOOLS=()

  # Claude Code — global install
  if [ -d "$HOME/.claude" ] || command -v claude >/dev/null 2>&1; then
    DETECTED_TOOLS+=("claude-code")
  fi

  # Cursor — check for app (macOS + Linux) + project-level dir
  if [ -d "/Applications/Cursor.app" ] || \
     [ -d "$HOME/Applications/Cursor.app" ] || \
     [ -d "$HOME/.config/Cursor" ] || \
     command -v cursor >/dev/null 2>&1 || \
     [ -d ".cursor" ]; then
    DETECTED_TOOLS+=("cursor")
  fi

  # Windsurf — check for app (macOS + Linux) + project-level dir
  if [ -d "/Applications/Windsurf.app" ] || \
     [ -d "$HOME/Applications/Windsurf.app" ] || \
     [ -d "$HOME/.config/Windsurf" ] || \
     command -v windsurf >/dev/null 2>&1 || \
     [ -d ".windsurf" ]; then
    DETECTED_TOOLS+=("windsurf")
  fi

  # Codex CLI
  if command -v codex >/dev/null 2>&1; then
    DETECTED_TOOLS+=("codex")
  fi
}

is_project_root() {
  [ -f "package.json" ] || [ -f "pyproject.toml" ] || [ -f "Cargo.toml" ] || \
  [ -f "go.mod" ] || [ -f "Gemfile" ] || [ -f "pubspec.yaml" ] || \
  [ -f "build.gradle" ] || [ -f "pom.xml" ] || [ -d ".git" ] || \
  [ -f "Makefile" ] || [ -f "CMakeLists.txt" ] || [ -f "*.sln" ] || \
  [ -f "composer.json" ] || [ -f "mix.exs" ] || [ -f "Package.swift" ]
}

warn_if_not_project_root() {
  local tool_name="$1"
  if ! is_project_root; then
    warn "CWD doesn't look like a project root (no package.json, .git, etc.)."
    warn "$tool_name agents install to the current directory: $(pwd)"
    if ! confirm_prompt "  Continue? (y/N) "; then
      return 1
    fi
  fi
  return 0
}

